{
  "name": "manghu",
  "version": "1.0.0",
  "private": true,
  "main": "server.js",
  "bin": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "build:exe": "pkg . --targets node20-win-x64 --output dist/Manghu.exe --compress GZip"
  },
  "pkg": {
    "assets": [
      "public/**/*",
      "data/achievements.json",
      "data/icon-mapping.json",
      "node_modules/node-unrar-js/esm/**/*"
    ],
    "scripts": [
      "data/sources/**/*.js"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "cheerio": "^1.0.0",
    "compression": "^1.7.4",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "node-unrar-js": "^2.0.2"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^5.11.0"
  }
}
